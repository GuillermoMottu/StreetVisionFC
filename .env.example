# .env.example — Variables de entorno para FutBotMX
#
# Copia este archivo como .env en la raíz del proyecto y ajusta las rutas.
# El archivo .env es cargado automáticamente por load_config() si existe.
# Requiere python-dotenv instalado, o se parsea manualmente como fallback.
#
# IMPORTANTE: .env nunca debe subirse a git (está en .gitignore).

# ── Rutas a videos de CopaFutMX ──────────────────────────────────────────────
FUTBOTMX_VIDEO_595=/path/to/video-595_singular_display.mov
FUTBOTMX_VIDEO_667=/path/to/video-667_singular_display.mov
FUTBOTMX_VIDEO_480=/path/to/video-480_singular_display.mov
FUTBOTMX_VIDEO_836=/path/to/video-836_singular_display.mov

# ── SAM 3 checkpoint ─────────────────────────────────────────────────────────
SAM3_CHECKPOINT_PATH=checkpoints/sam3/sam3.pt

# ── OWLv2 checkpoint ─────────────────────────────────────────────────────────
OWLV2_MODEL_PATH=checkpoints/owlv2-base

# ── PyTorch CUDA allocator (required for OWLv2+SAM3 on <8 GB VRAM) ──────────
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
