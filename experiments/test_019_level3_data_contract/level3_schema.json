{
  "rule_version": "level3_data_contract_v0.1",
  "schemas": [
    {
      "artifact_name": "level3_tracks.csv",
      "artifact_format": "csv",
      "required_fields": [
        "clip_id",
        "frame",
        "time_sec",
        "track_id",
        "source_track_id",
        "class_name",
        "team",
        "x",
        "y",
        "bbox_x1",
        "bbox_y1",
        "bbox_x2",
        "bbox_y2",
        "confidence",
        "x_norm",
        "y_norm",
        "zone",
        "calibration_id",
        "calibration_status",
        "calibration_confidence",
        "track_quality",
        "notes"
      ],
      "purpose": "Tracks heredados de Nivel 2 con coordenadas rectificadas/fallback y metadatos de calibracion.",
      "producer_stage": "Actividad 2 - Rectificacion Espacial Y Mini-Mapa",
      "consumer_stage": "Metricas tacticas, eventos avanzados, mini-mapa, Voronoi y dashboard.",
      "notes": ""
    },
    {
      "artifact_name": "level3_metrics.csv",
      "artifact_format": "csv",
      "required_fields": [
        "clip_id",
        "metric_category",
        "entity_type",
        "entity_id",
        "class_name",
        "team",
        "metric_name",
        "value",
        "unit",
        "frame_start",
        "frame_end",
        "confidence",
        "source",
        "notes"
      ],
      "purpose": "Metricas tacticas atomicas y comparables por clip, robot, equipo o evento.",
      "producer_stage": "Actividad 3 - Metricas Tacticas Avanzadas",
      "consumer_stage": "Dashboard, comparacion multi-clip y cierre Nivel 3.",
      "notes": ""
    },
    {
      "artifact_name": "level3_metrics.json",
      "artifact_format": "json",
      "required_fields": [
        "rule_version",
        "source",
        "summary",
        "spatial_control",
        "interactions",
        "pass_chains",
        "highlights",
        "assumptions",
        "limitations"
      ],
      "purpose": "Resumen legible de metricas tacticas y limitaciones por clip.",
      "producer_stage": "Actividad 3 - Metricas Tacticas Avanzadas",
      "consumer_stage": "Dashboard, README y resumen final Nivel 3.",
      "notes": ""
    },
    {
      "artifact_name": "level3_events.json",
      "artifact_format": "json",
      "required_fields": [
        "event_id",
        "event_type",
        "event_subtype",
        "clip_id",
        "frame_start",
        "frame_end",
        "time_start_sec",
        "time_end_sec",
        "team",
        "primary_object_id",
        "secondary_object_ids",
        "ball_id",
        "zone",
        "position_start",
        "position_end",
        "confidence",
        "reliability",
        "highlight_score",
        "source_event_ids",
        "interaction_edges",
        "spatial_context",
        "narrative",
        "rule_version",
        "evidence"
      ],
      "purpose": "Eventos avanzados: cadenas de pases, highlights, presion e interacciones.",
      "producer_stage": "Actividad 4 - Eventos Avanzados Nivel 3",
      "consumer_stage": "Narrativa, overlays, storyboard, dashboard y reel.",
      "notes": ""
    },
    {
      "artifact_name": "level3_highlights.csv",
      "artifact_format": "csv",
      "required_fields": [
        "clip_id",
        "highlight_id",
        "rank",
        "score",
        "event_type",
        "frame_start",
        "frame_end",
        "time_start_sec",
        "time_end_sec",
        "primary_track_id",
        "secondary_track_ids",
        "zone",
        "confidence",
        "reliability",
        "reason",
        "source_event_ids"
      ],
      "purpose": "Ranking de jugadas destacadas con score, confianza y razon.",
      "producer_stage": "Actividad 4 - Eventos Avanzados Nivel 3",
      "consumer_stage": "Storyboard, reel final, dashboard y validacion humana.",
      "notes": ""
    },
    {
      "artifact_name": "level3_narrative.md",
      "artifact_format": "markdown",
      "required_fields": [
        "title",
        "clip_id",
        "event_sections",
        "limitations"
      ],
      "purpose": "Narrativa deportiva generada por reglas, con lenguaje conservador.",
      "producer_stage": "Actividad 4 - Eventos Avanzados Nivel 3",
      "consumer_stage": "Dashboard, reel final y README.",
      "notes": "Markdown no usa columnas CSV; los campos representan secciones obligatorias."
    },
    {
      "artifact_name": "level3_visualization_manifest.csv",
      "artifact_format": "csv",
      "required_fields": [
        "clip_id",
        "asset_id",
        "asset_type",
        "path",
        "source_artifact",
        "frame_start",
        "frame_end",
        "event_id",
        "is_versioned",
        "notes"
      ],
      "purpose": "Indice de PNG/GIF/video local asociado a visualizaciones Nivel 3.",
      "producer_stage": "Actividades 5, 6 y 7",
      "consumer_stage": "Dashboard, cierre Nivel 3 y control anti-archivos-pesados.",
      "notes": ""
    }
  ]
}
